# VerdictIQ Backend Environment Variables Configuration Template
# Copy this file to .env and configure the variables with actual credentials before launching the server.

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/VerdictIQ?retryWrites=true&w=majority
DATABASE_NAME=VerdictIQ
JWT_SECRET_KEY=generate_a_random_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

GEMINI_API_KEY=your_google_studio_gemini_api_key
